# ══════════════════════════════════════════════════════════════════════
#  OM Computers — environment variables
#  In production, set these in Hostinger hPanel → your Node.js web app →
#  Environment variables (NOT committed to git). See HOSTINGER-DEPLOYMENT.md.
# ══════════════════════════════════════════════════════════════════════

# ── Database (MySQL, created in hPanel → Databases → MySQL) ───────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=omcomputers
DB_USER=omcomputers_user
DB_PASSWORD=

# ── Admin panel login (/admin) ───────────────────────────────────────
# The password you type to log in. Choose a long, unique one.
ADMIN_PASSWORD=
# Random 64-char hex string used to sign the login session cookie.
# Generate with:  openssl rand -hex 32
ADMIN_SECRET=

# Canonical site URL (used for SEO/canonical tags, read at build time).
SITE_URL=https://omcomputers.net

# Optional: the app already binds 0.0.0.0 by default; only set HOST if the
# platform requires it. PORT is provided by the host automatically.
# HOST=0.0.0.0
