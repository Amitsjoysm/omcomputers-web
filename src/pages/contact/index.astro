---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';

const site = await import('../../content/settings/site.json').then(m => m.default).catch(() => ({
  phone: '+91 98765 43210',
  whatsapp: '919876543210',
  email: 'info@omcomputers.co',
  address: 'Pune, Maharashtra',
  openHours: 'Monday to Saturday, 9 AM – 7 PM',
  googleMaps: '',
}));
---

<BaseLayout
  title="Contact Us"
  description="Contact OM Computers in Pune. Call, WhatsApp, or visit us for device repair, CCTV installation, biometric systems, and IT support."
>
  <Navbar />

  <main>
    <!-- Page Hero -->
    <section style="background:var(--surface-2); padding:var(--sp-8) 0; border-bottom:1px solid var(--border); text-align:center;">
      <div class="container">
        <p class="eyebrow">Get In Touch</p>
        <h1 style="font-size:clamp(28px,4vw,42px); font-weight:800; font-family:var(--font-display); margin:var(--sp-2) 0 var(--sp-3);">
          Contact Us
        </h1>
        <p class="lead" style="max-width:480px; margin:0 auto;">
          Walk in, call, or send us a message. We respond within 1 business hour during opening hours.
        </p>
      </div>
    </section>

    <section style="padding:var(--sp-8) 0;">
      <div class="container">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:var(--sp-8); align-items:start;">

          <!-- Contact Info -->
          <div>
            <h2 style="font-size:24px; font-weight:700; font-family:var(--font-display); margin-bottom:var(--sp-5);">
              How to Reach Us
            </h2>

            <div style="display:flex; flex-direction:column; gap:var(--sp-4); margin-bottom:var(--sp-6);">
              <a href={`tel:${site.phone.replace(/\s/g,'')}`} style="display:flex; align-items:center; gap:var(--sp-3); padding:var(--sp-4); background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-md); text-decoration:none; color:inherit; transition:box-shadow 150ms;" class="contact-item">
                <div style="width:44px; height:44px; background:var(--primary-light); border-radius:var(--radius-sm); display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0;">📞</div>
                <div>
                  <div style="font-size:12px; color:var(--text-muted); font-weight:600; text-transform:uppercase; letter-spacing:.06em; margin-bottom:2px;">Phone</div>
                  <div style="font-size:16px; font-weight:600; color:var(--primary);">{site.phone}</div>
                </div>
              </a>

              <a href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener" style="display:flex; align-items:center; gap:var(--sp-3); padding:var(--sp-4); background:#F0FFF4; border:1px solid #A8E6CF; border-radius:var(--radius-md); text-decoration:none; color:inherit; transition:box-shadow 150ms;" class="contact-item">
                <div style="width:44px; height:44px; background:#25D366; border-radius:var(--radius-sm); display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0;">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.558 4.109 1.533 5.83L.057 23.926a.5.5 0 0 0 .609.61l6.253-1.633A11.943 11.943 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22a9.944 9.944 0 0 1-5.174-1.448l-.371-.22-3.844 1.005 1.027-3.742-.241-.385A9.944 9.944 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
                </div>
                <div>
                  <div style="font-size:12px; color:#1A7A43; font-weight:600; text-transform:uppercase; letter-spacing:.06em; margin-bottom:2px;">WhatsApp</div>
                  <div style="font-size:16px; font-weight:600; color:#1A7A43;">Chat with us now</div>
                </div>
              </a>

              <a href={`mailto:${site.email}`} style="display:flex; align-items:center; gap:var(--sp-3); padding:var(--sp-4); background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-md); text-decoration:none; color:inherit; transition:box-shadow 150ms;" class="contact-item">
                <div style="width:44px; height:44px; background:var(--primary-light); border-radius:var(--radius-sm); display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0;">✉️</div>
                <div>
                  <div style="font-size:12px; color:var(--text-muted); font-weight:600; text-transform:uppercase; letter-spacing:.06em; margin-bottom:2px;">Email</div>
                  <div style="font-size:16px; font-weight:600; color:var(--primary);">{site.email}</div>
                </div>
              </a>

              <div style="display:flex; align-items:flex-start; gap:var(--sp-3); padding:var(--sp-4); background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-md);">
                <div style="width:44px; height:44px; background:var(--primary-light); border-radius:var(--radius-sm); display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0;">📍</div>
                <div>
                  <div style="font-size:12px; color:var(--text-muted); font-weight:600; text-transform:uppercase; letter-spacing:.06em; margin-bottom:2px;">Address</div>
                  <div style="font-size:15px; color:var(--text-primary); line-height:1.5;">{site.address}</div>
                </div>
              </div>

              <div style="display:flex; align-items:center; gap:var(--sp-3); padding:var(--sp-4); background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-md);">
                <div style="width:44px; height:44px; background:var(--primary-light); border-radius:var(--radius-sm); display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0;">🕘</div>
                <div>
                  <div style="font-size:12px; color:var(--text-muted); font-weight:600; text-transform:uppercase; letter-spacing:.06em; margin-bottom:2px;">Opening Hours</div>
                  <div style="font-size:15px; color:var(--text-primary);">{site.openHours}</div>
                </div>
              </div>
            </div>

            <!-- Map -->
            {site.googleMaps && (
              <div style="border-radius:var(--radius-lg); overflow:hidden; border:1px solid var(--border);">
                <iframe
                  src={site.googleMaps}
                  width="100%"
                  height="280"
                  style="border:0; display:block;"
                  allowfullscreen
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="OM Computers location on Google Maps"
                ></iframe>
              </div>
            )}
          </div>

          <!-- Contact Form -->
          <div>
            <h2 style="font-size:24px; font-weight:700; font-family:var(--font-display); margin-bottom:var(--sp-5);">
              Send Us a Message
            </h2>

            <form
              name="contact"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              style="display:flex; flex-direction:column; gap:var(--sp-4);"
            >
              <input type="hidden" name="form-name" value="contact" />
              <p style="display:none;"><input name="bot-field" /></p>

              <div style="display:grid; grid-template-columns:1fr 1fr; gap:var(--sp-3);">
                <div class="form-group">
                  <label for="name" class="form-label">Full Name *</label>
                  <input type="text" id="name" name="name" required class="form-input" placeholder="Your name" autocomplete="name" />
                </div>
                <div class="form-group">
                  <label for="phone" class="form-label">Phone Number *</label>
                  <input type="tel" id="phone" name="phone" required class="form-input" placeholder="+91 XXXXX XXXXX" autocomplete="tel" />
                </div>
              </div>

              <div class="form-group">
                <label for="service" class="form-label">Service Required</label>
                <select id="service" name="service" class="form-input">
                  <option value="">Select a service...</option>
                  <option value="Device Repair">Device Repair (Laptop / Desktop / Printer)</option>
                  <option value="CCTV">CCTV Installation</option>
                  <option value="Biometric">Biometric &amp; Access Control</option>
                  <option value="IT Support">IT Support &amp; AMC</option>
                  <option value="Web Services">Web &amp; Digital Services</option>
                  <option value="Hardware">Hardware Sales &amp; Upgrades</option>
                  <option value="Other">Other</option>
                </select>
              </div>

              <div class="form-group">
                <label for="message" class="form-label">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  class="form-input"
                  placeholder="Describe your issue or requirements..."
                  style="resize:vertical; min-height:120px;"
                ></textarea>
              </div>

              <button type="submit" class="btn-primary" style="width:100%; justify-content:center; padding:14px; font-size:16px;">
                Send Message →
              </button>

              <p style="font-size:13px; color:var(--text-muted); text-align:center;">
                We respond within 1 business hour. Your information is never shared.
              </p>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <style>
    .contact-item:hover { box-shadow: var(--shadow-raise); }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-label {
      font-size: 13px; font-weight: 600; color: var(--text-secondary);
      letter-spacing: .02em;
    }
    .form-input {
      padding: 11px 14px;
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      font-size: 15px;
      font-family: var(--font-body);
      color: var(--text-primary);
      background: var(--surface);
      transition: border-color 150ms, box-shadow 150ms;
      width: 100%;
    }
    .form-input:focus {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 0 3px var(--primary-light);
    }
    .form-input::placeholder { color: var(--text-muted); }

    @media (max-width: 768px) {
      section > .container > div {
        grid-template-columns: 1fr !important;
      }
      .form-group:has(#name) ~ .form-group:has(#phone) { display: block; }
    }
    @media (max-width: 600px) {
      form > div:first-of-type { grid-template-columns: 1fr !important; }
    }
  </style>

  <Footer />
</BaseLayout>
