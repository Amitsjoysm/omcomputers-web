---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import TagFilter from '../../components/blog/TagFilter.tsx';

const allPosts = await getCollection('blog', ({ data }) => data.published);
const sorted = allPosts.sort((a, b) =>
  b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
const allTags = [...new Set(sorted.flatMap(p => p.data.tags))].sort();

// Serialize for React island
const postsForFilter = sorted.map(p => ({
  slug: p.slug,
  data: {
    title: p.data.title,
    excerpt: p.data.excerpt,
    tags: p.data.tags,
    publishDate: p.data.publishDate.toISOString(),
    coverImage: p.data.coverImage ? { src: p.data.coverImage.src, width: p.data.coverImage.width, height: p.data.coverImage.height } : undefined,
  },
}));
---

<BaseLayout
  title="Blog & Project Updates"
  description="Tips, guides, and updates from OM Computers: computer repair advice, CCTV guides, IT security tips, and more."
>
  <Navbar />

  <main id="main-content">
    <!-- Page Hero -->
    <section style="background:var(--surface-2); padding:var(--sp-6) 0; border-bottom:1px solid var(--border);">
      <div class="container" style="text-align:center;">
        <p class="eyebrow">Knowledge Base</p>
        <h1 style="font-size:clamp(28px,4vw,42px); font-weight:800; font-family:var(--font-display); margin:var(--sp-2) 0 var(--sp-3);">
          Blog &amp; Project Updates
        </h1>
        <p class="lead" style="max-width:520px; margin:0 auto;">
          Tips, guides, and updates from the OM Computers team. Learn how to protect, maintain, and get the most from your technology.
        </p>
      </div>
    </section>

    <!-- Blog listing with tag filter -->
    <section style="padding:var(--sp-7) 0;">
      <div class="container">
        {sorted.length === 0 ? (
          <div style="text-align:center; padding:var(--sp-7) 0;">
            <div style="font-size:64px; margin-bottom:var(--sp-4);">📝</div>
            <h2 style="font-family:var(--font-display); margin-bottom:var(--sp-2);">No posts yet</h2>
            <p style="color:var(--text-secondary);">Check back soon. We are working on some useful content.</p>
          </div>
        ) : (
          <TagFilter client:load posts={postsForFilter} tags={allTags} />
        )}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
