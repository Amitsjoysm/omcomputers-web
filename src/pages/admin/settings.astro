---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSettings, saveSettings } from '../../lib/content';

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const phone = String(form.get('phone') ?? '').trim();
  const email = String(form.get('email') ?? '').trim();
  if (!phone || !email) {
    error = 'Phone and email are required.';
  } else {
    await saveSettings({
      phone,
      whatsapp: String(form.get('whatsapp') ?? '').trim().replace(/[^0-9]/g, ''),
      email,
      address: String(form.get('address') ?? '').trim(),
      googleMaps: String(form.get('googleMaps') ?? '').trim(),
      openHours: String(form.get('openHours') ?? '').trim(),
    });
    return Astro.redirect('/admin/settings?saved=1');
  }
}

const settings = await getSettings();
const saved = Astro.url.searchParams.has('saved');
---

<AdminLayout title="Site Settings" active="settings">
  <h1 class="admin-h1">Site Settings</h1>
  <p style="color:var(--text-secondary); font-size:14px; margin:-8px 0 var(--sp-4);">
    Shown in the header, footer, and contact page across the whole site. Changes appear immediately.
  </p>

  {saved && <p class="flash flash-ok">Settings saved — live on the site now.</p>}
  {error && <p class="flash flash-err">{error}</p>}

  <form method="POST" class="admin-card" style="max-width:640px;">
    <div class="field-row">
      <div class="field">
        <label for="phone">Phone number *</label>
        <input type="text" id="phone" name="phone" required value={settings.phone} />
      </div>
      <div class="field">
        <label for="whatsapp">WhatsApp number</label>
        <input type="text" id="whatsapp" name="whatsapp" value={settings.whatsapp} />
        <p class="hint">With country code, digits only — e.g. 919876543210</p>
      </div>
    </div>

    <div class="field">
      <label for="email">Email address *</label>
      <input type="email" id="email" name="email" required value={settings.email} />
    </div>

    <div class="field">
      <label for="address">Full address</label>
      <textarea id="address" name="address" rows="2">{settings.address}</textarea>
    </div>

    <div class="field">
      <label for="googleMaps">Google Maps embed URL</label>
      <input type="url" id="googleMaps" name="googleMaps" value={settings.googleMaps} />
      <p class="hint">Google Maps → Share → Embed a map → copy the src="…" address.</p>
    </div>

    <div class="field">
      <label for="openHours">Opening hours</label>
      <input type="text" id="openHours" name="openHours" value={settings.openHours} placeholder="Monday to Saturday, 9 AM – 7 PM" />
    </div>

    <button type="submit" class="btn-primary">Save settings</button>
  </form>
</AdminLayout>
