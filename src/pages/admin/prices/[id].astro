---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import {
  getCategory, listCategoriesWithItems,
  createItem, updateItem, deleteItem, getItem, type ItemInput,
} from '../../../lib/content';
import { requestTooLarge, storeUpload } from '../../../lib/admin-forms';

const categoryId = Number(Astro.params.id);
if (!Number.isInteger(categoryId) || categoryId <= 0) return Astro.redirect('/admin/prices');

const category = await getCategory(categoryId);
if (!category) return Astro.redirect('/admin/prices');

let error = '';

async function parseItem(form: FormData, currentImage: string | null): Promise<{ input?: ItemInput; error?: string }> {
  const name = String(form.get('name') ?? '').trim();
  if (!name) return { error: 'Product name is required.' };
  let image = currentImage;
  if (form.get('removeImage') === 'on') image = null;
  const upload = await storeUpload(form.get('image'));
  if (upload.error) return { error: upload.error };
  if (upload.url) image = upload.url;
  return {
    input: {
      name,
      brand: String(form.get('brand') ?? '').trim(),
      specs: String(form.get('specs') ?? '').trim(),
      price: Math.max(0, Number(form.get('price')) || 0),
      inStock: form.get('inStock') === 'on',
      image,
    },
  };
}

if (Astro.request.method === 'POST') {
  if (requestTooLarge(Astro.request)) {
    error = 'Upload too large — images must be under 5 MB.';
  } else {
    const form = await Astro.request.formData();
    const action = form.get('action');

    if (action === 'add-item') {
      const parsed = await parseItem(form, null);
      if (parsed.error) error = parsed.error;
      else {
        await createItem(categoryId, parsed.input!);
        return Astro.redirect(`/admin/prices/${categoryId}?saved=1`);
      }
    } else if (action === 'save-item') {
      const itemId = Number(form.get('item_id'));
      const existing = Number.isInteger(itemId) ? await getItem(itemId) : null;
      if (!existing || existing.categoryId !== categoryId) {
        error = 'Product not found.';
      } else {
        const parsed = await parseItem(form, existing.image?.src ?? null);
        if (parsed.error) error = parsed.error;
        else {
          await updateItem(itemId, parsed.input!);
          return Astro.redirect(`/admin/prices/${categoryId}?saved=1`);
        }
      }
    } else if (action === 'delete-item') {
      const itemId = Number(form.get('item_id'));
      const existing = Number.isInteger(itemId) ? await getItem(itemId) : null;
      if (existing && existing.categoryId === categoryId) await deleteItem(itemId);
      return Astro.redirect(`/admin/prices/${categoryId}?saved=1`);
    }
  }
}

const all = await listCategoriesWithItems();
const items = all.find(c => c.id === categoryId)?.data.items ?? [];
const saved = Astro.url.searchParams.has('saved');
---

<AdminLayout title={`Prices: ${category.name}`} active="prices">
  <div style="display:flex; align-items:center; gap:var(--sp-3); margin-bottom:var(--sp-4); flex-wrap:wrap;">
    <a href="/admin/prices" style="color:var(--text-muted); font-size:14px;">← Categories</a>
    <h1 class="admin-h1" style="margin:0;">{category.name}</h1>
  </div>

  {saved && <p class="flash flash-ok">Saved.</p>}
  {error && <p class="flash flash-err">{error}</p>}

  {items.map(item => (
    <form method="POST" enctype="multipart/form-data" class="admin-card" style="padding:var(--sp-4);">
      <input type="hidden" name="action" value="save-item" />
      <input type="hidden" name="item_id" value={item.id} />
      <div style="display:grid; grid-template-columns: 2fr 1fr 1fr; gap:var(--sp-3); margin-bottom:var(--sp-3);">
        <div class="field" style="margin:0;">
          <label>Product name</label>
          <input type="text" name="name" required value={item.name} />
        </div>
        <div class="field" style="margin:0;">
          <label>Brand</label>
          <input type="text" name="brand" value={item.brand} />
        </div>
        <div class="field" style="margin:0;">
          <label>Price (INR)</label>
          <input type="number" name="price" min="0" step="1" value={item.price} />
        </div>
      </div>
      <div class="field" style="margin-bottom:var(--sp-3);">
        <label>Specs</label>
        <input type="text" name="specs" value={item.specs} placeholder="e.g. 10-Core · 2.5 GHz · LGA1700" />
      </div>
      <div style="display:flex; align-items:center; gap:var(--sp-4); flex-wrap:wrap;">
        <label class="check"><input type="checkbox" name="inStock" checked={item.inStock} /> In stock</label>
        {item.image && (
          <span style="display:inline-flex; align-items:center; gap:var(--sp-2);">
            <img src={item.image.src} alt="" style="height:36px; width:36px; object-fit:cover; border-radius:6px; border:1px solid var(--border);" />
            <label class="check" style="font-size:13px;"><input type="checkbox" name="removeImage" /> remove</label>
          </span>
        )}
        <input type="file" name="image" accept="image/*" style="font-size:13px;" />
        <span style="flex:1;"></span>
        <button type="submit" class="btn-primary" style="padding:8px 18px; font-size:13px;">Save</button>
        <button type="submit" class="btn-danger" style="padding:8px 14px; font-size:13px;"
          formnovalidate name="action" value="delete-item"
          onclick="return confirm('Delete this product?');">Delete</button>
      </div>
    </form>
  ))}

  <form method="POST" enctype="multipart/form-data" class="admin-card" style="border-style:dashed;">
    <input type="hidden" name="action" value="add-item" />
    <h2 class="admin-h2">Add a product to {category.name}</h2>
    <div style="display:grid; grid-template-columns: 2fr 1fr 1fr; gap:var(--sp-3); margin-bottom:var(--sp-3);">
      <div class="field" style="margin:0;">
        <label>Product name *</label>
        <input type="text" name="name" required placeholder="e.g. Intel Core i5-13400F" />
      </div>
      <div class="field" style="margin:0;">
        <label>Brand</label>
        <input type="text" name="brand" placeholder="e.g. Intel" />
      </div>
      <div class="field" style="margin:0;">
        <label>Price (INR)</label>
        <input type="number" name="price" min="0" step="1" value="0" />
      </div>
    </div>
    <div class="field" style="margin-bottom:var(--sp-3);">
      <label>Specs</label>
      <input type="text" name="specs" placeholder="Short spec line shown on the card" />
    </div>
    <div style="display:flex; align-items:center; gap:var(--sp-4); flex-wrap:wrap;">
      <label class="check"><input type="checkbox" name="inStock" checked /> In stock</label>
      <input type="file" name="image" accept="image/*" style="font-size:13px;" />
      <span style="flex:1;"></span>
      <button type="submit" class="btn-primary">Add product</button>
    </div>
  </form>
</AdminLayout>
