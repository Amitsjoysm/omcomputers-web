---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { listAllPosts, listCategoriesWithItems, countUnreadMessages } from '../../lib/content';

const posts = await listAllPosts();
const categories = await listCategoriesWithItems();
const publishedCount = posts.filter(p => p.published).length;
const draftCount = posts.length - publishedCount;
const itemCount = categories.reduce((n, c) => n + c.data.items.length, 0);
const unread = await countUnreadMessages();
---

<AdminLayout title="Dashboard" active="dashboard">
  <h1 class="admin-h1">Dashboard</h1>

  <div class="grid-3" style="margin-bottom: var(--sp-5);">
    <a href="/admin/posts" class="admin-card" style="margin:0; display:block; color:inherit;">
      <div style="font-size:32px; font-weight:800; font-family:var(--font-display); color:var(--primary);">{publishedCount}</div>
      <div style="font-size:14px; color:var(--text-secondary);">Published posts {draftCount > 0 && <span class="badge badge-warning">+{draftCount} draft{draftCount > 1 ? 's' : ''}</span>}</div>
    </a>
    <a href="/admin/prices" class="admin-card" style="margin:0; display:block; color:inherit;">
      <div style="font-size:32px; font-weight:800; font-family:var(--font-display); color:var(--primary);">{itemCount}</div>
      <div style="font-size:14px; color:var(--text-secondary);">Products in {categories.length} categories</div>
    </a>
    <a href="/admin/messages" class="admin-card" style="margin:0; display:block; color:inherit;">
      <div style="font-size:32px; font-weight:800; font-family:var(--font-display); color:var(--primary);">{unread}</div>
      <div style="font-size:14px; color:var(--text-secondary);">Unread enquiries</div>
    </a>
  </div>

  <div class="admin-card">
    <h2 class="admin-h2">Quick actions</h2>
    <div style="display:flex; gap:var(--sp-3); flex-wrap:wrap;">
      <a href="/admin/posts/new" class="btn-primary">✍ Write a new post</a>
      <a href="/admin/prices" class="btn-outline">Update prices</a>
      <a href="/admin/settings" class="btn-outline">Edit contact details</a>
    </div>
  </div>

  <div class="admin-card">
    <h2 class="admin-h2">Recent posts</h2>
    {posts.length === 0 ? (
      <p style="color:var(--text-muted); font-size:14px;">No posts yet. Write your first one!</p>
    ) : (
      <table class="admin-table">
        <thead><tr><th>Title</th><th>Date</th><th>Status</th></tr></thead>
        <tbody>
          {posts.slice(0, 5).map(post => (
            <tr>
              <td><a href={`/admin/posts/${post.id}`} style="color:var(--primary); font-weight:600;">{post.data.title}</a></td>
              <td style="white-space:nowrap;">{post.data.publishDate.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}</td>
              <td>{post.published ? <span class="badge badge-success">Published</span> : <span class="badge badge-warning">Draft</span>}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
