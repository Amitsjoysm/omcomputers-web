---
import type { PostFull } from '../../lib/content';

export interface Props {
  post?: PostFull | null;
  error?: string;
  saved?: boolean;
  uploadedImageUrl?: string | null;
}

const { post = null, error = '', saved = false, uploadedImageUrl = null } = Astro.props;

const dateValue = post
  ? post.data.publishDate.toISOString().slice(0, 10)
  : new Date().toISOString().slice(0, 10);
---

{saved && <p class="flash flash-ok">Saved. {post?.published ? <a href={`/blog/${post.slug}`} target="_blank" rel="noopener">View the post ↗</a> : 'Still a draft — tick "Published" when ready.'}</p>}
{error && <p class="flash flash-err">{error}</p>}

<form method="POST" enctype="multipart/form-data" class="admin-card">
  <input type="hidden" name="action" value="save" />

  <div class="field">
    <label for="title">Title *</label>
    <input type="text" id="title" name="title" required maxlength="255" value={post?.data.title ?? ''} />
  </div>

  <div class="field-row">
    <div class="field">
      <label for="slug">URL slug</label>
      <input type="text" id="slug" name="slug" value={post?.slug ?? ''} placeholder="leave empty to auto-generate from title" />
      <p class="hint">The post address: /blog/<strong>your-slug</strong></p>
    </div>
    <div class="field">
      <label for="publishDate">Publish date</label>
      <input type="date" id="publishDate" name="publishDate" value={dateValue} />
    </div>
  </div>

  <div class="field">
    <label for="excerpt">Excerpt</label>
    <textarea id="excerpt" name="excerpt" rows="2" maxlength="160" placeholder="One or two sentences shown on the blog listing (max 160 characters)">{post?.data.excerpt ?? ''}</textarea>
  </div>

  <div class="field">
    <label for="tags">Tags</label>
    <input type="text" id="tags" name="tags" value={post?.data.tags.join(', ') ?? ''} placeholder="CCTV, Repair, Tips" />
    <p class="hint">Separate with commas.</p>
  </div>

  <div class="field">
    <label for="cover">Cover image {post?.data.coverImage && '(replace current)'}</label>
    {post?.data.coverImage && (
      <div style="margin-bottom:var(--sp-2);">
        <img src={post.data.coverImage.src} alt="Current cover" style="max-height:120px; border-radius:var(--radius-sm); border:1px solid var(--border);" />
        <label class="check" style="margin-top:var(--sp-2);">
          <input type="checkbox" name="removeCover" /> Remove cover image
        </label>
      </div>
    )}
    <input type="file" id="cover" name="cover" accept="image/*" />
    <p class="hint">16:9 ratio recommended. Max 5 MB.</p>
  </div>

  <div class="field">
    <label for="body">Post body (Markdown)</label>
    <textarea id="body" name="body" rows="18" style="font-family:var(--font-mono); font-size:13px;">{post?.body ?? ''}</textarea>
    <p class="hint">
      Formatting: <code>**bold**</code> · <code>## Heading</code> · <code>- bullet</code> ·
      <code>[link text](https://url)</code> · <code>![photo](/api/images/1)</code> — upload images below to get their address.
    </p>
  </div>

  <div class="field">
    <label class="check">
      <input type="checkbox" name="published" checked={post?.published ?? false} />
      Published (unticked = draft, hidden from the site)
    </label>
  </div>

  <div style="display:flex; gap:var(--sp-3); align-items:center;">
    <button type="submit" class="btn-primary">Save post</button>
    <a href="/admin/posts" style="font-size:14px; color:var(--text-secondary);">Cancel</a>
  </div>
</form>

{post && (
  <form method="POST" enctype="multipart/form-data" class="admin-card">
    <input type="hidden" name="action" value="upload-image" />
    <h2 class="admin-h2">Insert an image into the post</h2>
    {uploadedImageUrl && (
      <p class="flash flash-ok" style="word-break:break-all;">
        Uploaded! Copy this into the post body where you want the image:<br />
        <code>![describe the image]({uploadedImageUrl})</code>
      </p>
    )}
    <div class="field">
      <input type="file" name="inlineImage" accept="image/*" required />
      <p class="hint">Upload, then copy the snippet into the post body above. Max 5 MB.</p>
    </div>
    <button type="submit" class="btn-outline">Upload image</button>
  </form>
)}
